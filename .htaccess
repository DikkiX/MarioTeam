RewriteEngine On

# Dit maakt /api/chat/send beschikbaar zonder .php in de URL.
RewriteRule ^api/chat/send/?$ api/chat/send.php [L,QSA]

# Dit pad laat de frontend de status van 1 bericht ophalen.
RewriteRule ^api/chat/status/?$ api/chat/status.php [L,QSA]

# Dit pad start het worker-script.
RewriteRule ^api/chat/worker/?$ api/chat/worker.php [L,QSA]
RewriteRule ^api/google/oauth/callback/?$ api/google/oauth/callback.php [L,QSA]
